# .env is gitignored — copy this file to .env and fill in values.
#
# Development:  docker compose -f docker-compose.dev.yml up
# Production:   docker compose -f docker-compose.prod.yml up -d


# ── Database ──────────────────────────────────────────────
# DEV  — individual vars are used by the local Postgres container
#         and auto-composed into DATABASE_URL by docker-compose.dev.yml.
POSTGRES_USER=fedrl
POSTGRES_PASSWORD=fedrl
POSTGRES_DB=fedrl
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# PROD — set DATABASE_URL directly to point at RDS (overrides the vars above).
# DATABASE_URL=postgresql+asyncpg://fedrl:<password>@<rds-endpoint>:5432/fedrl


# ── FastAPI server ────────────────────────────────────────
# Set to "true" to log all SQL queries (dev only)
SQL_ECHO=false

# Comma-separated allowed origins for CORS (use * for dev, restrict in prod)
CORS_ALLOW_ORIGINS=*

# Number of Uvicorn worker processes (match to vCPU count; 1 for dev, 2 for t3.small)
# Should be 1 for production as the server stores the round queues in memory.
UVICORN_WORKERS=1


# ── Aggregator ────────────────────────────────────────────
# Exact number of unique clients that must upload before a FedAvg round runs. (Should be equal to CENTRALIZED_CLIENTS_PER_ROUND)
FEDERATED_CLIENTS_PER_ROUND=2

# ── Centralized Service ───────────────────────────────────
# Exact number of unique clients that must upload before a centralized
# training round runs. (Should be equal to FEDERATED_CLIENTS_PER_ROUND so the
# two arms train on the same number of client contributions per round.)
CENTRALIZED_CLIENTS_PER_ROUND=2

# Maximum number of tuples to store in the tuple pool.
# Should be equal to FEDERATED_CLIENTS_PER_ROUND * client limit tuple count so the two arms train on the same number of client contributions per round.
MAX_TUPLE_POOL_SIZE=2000
