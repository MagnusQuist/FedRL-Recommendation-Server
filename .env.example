# .env is gitignored — copy this file to .env and fill in values.
#
# Development:  docker compose -f docker-compose.dev.yml up
# Production:   docker compose -f docker-compose.prod.yml up -d


# ── Database ──────────────────────────────────────────────
# DEV  — individual vars are used by the local Postgres container
#         and auto-composed into DATABASE_URL by docker-compose.dev.yml.
POSTGRES_USER=fedrl
POSTGRES_PASSWORD=fedrl
POSTGRES_DB=fedrl
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# PROD — set DATABASE_URL directly to point at RDS (overrides the vars above).
# DATABASE_URL=postgresql+asyncpg://fedrl:<password>@<rds-endpoint>:5432/fedrl


# ── FastAPI server ────────────────────────────────────────
# Set to "true" to log all SQL queries (dev only)
SQL_ECHO=false

# Catalogue version string — update when the catalogue seed data changes
CATALOGUE_VERSION=2026-01-01T00:00:00Z

# Comma-separated allowed origins for CORS (use * for dev, restrict in prod)
CORS_ALLOW_ORIGINS=*

# Number of Uvicorn worker processes (match to vCPU count; 1 for dev, 2 for t3.small)
UVICORN_WORKERS=1


# ── Federated Learning ────────────────────────────────────
FL_MIN_CLIENTS_PER_ROUND=2
FL_ROUND_TIMEOUT_SECONDS=3600

# Path to the backbone_weights.npz produced by the pretrain script.
# Both federated and centralized backbones are seeded from this file.
PRETRAINED_WEIGHTS_PATH=data/pretrained/pretrained_backbone_weights.npz


# ── Database models ───────────────────────────────────────
# "true" = SQLAlchemy metadata.create_all() on startup (creates missing tables).
# Safe for dev; set to "false" in production after initial setup.
AUTO_CREATE_MODELS=true
