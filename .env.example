# .env is gitignored

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=fedrl
POSTGRES_PASSWORD=fedrl
POSTGRES_DB=fedrl
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── FastAPI server ────────────────────────────────────────
# Set to "true" to log all SQL queries (useful during development)
SQL_ECHO=false

# Catalogue version string — update when the catalogue seed data changes
CATALOGUE_VERSION=2026-01-01T00:00:00Z

# ── Federated Learning ────────────────────────────────────
FL_MIN_CLIENTS_PER_ROUND=2
FL_ROUND_TIMEOUT_SECONDS=3600

SUPPORTED_BACKBONE_ALGORITHMS=ts,dqn
DEFAULT_BACKBONE_ALGORITHMS=ts,dqn
BACKBONE_INIT_SEED=42

# ── pgAdmin ───────────────────────────────────────────────
PGADMIN_EMAIL=admin@gmail.com
PGADMIN_PASSWORD=admin

# ── Database schema & startup seed ────────────────────────
# "true" = SQLAlchemy metadata.create_all() on startup (creates missing tables only). Docker defaults to true.
AUTO_CREATE_SCHEMA=true
# Backbone + catalogue seed runs in the background after bind (avoids blocking startup on large JSON)
AUTO_SEED_DATA_ON_STARTUP=true
